# Napoli Pizzeria generated MCP skeleton
# Optional. Defaults to the scanned website root URL when unset.
CUSTOMER_API_BASE_URL=https://pizza-test-app-jade.vercel.app

# HTTP port for the generated Streamable HTTP MCP server.
PORT=3000

# TODO: Add a customer-scoped token only after auth requirements are confirmed.
CUSTOMER_API_TOKEN=

# TODO: Keep false until a human-confirmation UX/policy gate is implemented for mutations.
ENABLE_MUTATIONS=false
