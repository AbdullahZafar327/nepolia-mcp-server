{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "outDir": "dist",
    "lib": [
      "ES2022",
      "DOM"
    ]
  },
  "include": [
    "server.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}